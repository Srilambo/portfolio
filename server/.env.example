# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/portfolio
# For MongoDB Atlas use:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Admin credentials (single hardcoded admin — no user table needed)
ADMIN_EMAIL=admin@raavanaa.lk
ADMIN_PASSWORD=change_me_before_deploy

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars

# SMTP (Gmail example — use App Password if 2FA is enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email destination for contact form submissions
EMAIL_TO=hello@raavanaa.lk

# Frontend URL (used for CORS + auto-reply links)
CLIENT_URL=http://localhost:3000

# GitHub
GITHUB_USERNAME=raavanaa
# Optional — increases rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_your_optional_token
