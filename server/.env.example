# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/portfolio
# For MongoDB Atlas use:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Admin credentials (single hardcoded admin — no user table needed)
ADMIN_EMAIL=admin@raavanaa.lk
ADMIN_PASSWORD=change_me_before_deploy

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string_min_32_chars

# SMTP (Gmail example — use App Password if 2FA is enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Email destination for contact form submissions
EMAIL_TO=hello@raavanaa.lk

# Frontend URL (used for CORS + auto-reply links)
CLIENT_URL=http://localhost:3000

# GitHub
GITHUB_USERNAME=raavanaa
# Optional — increases rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_your_optional_token

# ── WhatsApp Admin Notifications ──────────────────────────────
# --- Option 1: WASender API ---
WASENDER_API_KEY=your_wasender_api_key_here
WASENDER_RECIPIENT_NUMBER=94756192686
# Optional — default is https://wasenderapi.com/api/send-message
# WASENDER_API_URL=https://wasenderapi.com/api/send-message

# --- Option 2: Official Meta Business Cloud API ---
META_WA_ACCESS_TOKEN=your_meta_system_user_token
META_WA_PHONE_NUMBER_ID=your_meta_phone_number_id
META_WA_RECIPIENT_NUMBER=94756192686
META_WA_TEMPLATE_NAME=

# --- Option 3: CallMeBot Fallback ---
WHATSAPP_ADMIN_NUMBER=+94756192686
WHATSAPP_API_KEY=your_callmebot_api_key


